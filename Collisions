<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Collisions</title><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Arial,sans-serif;background:transparent;padding:20px}h1{text-align:center;color:#495057;margin-bottom:15px;font-size:24px}.container{max-width:800px;margin:0 auto}.panel{background:#fff;border:2px solid #495057;border-radius:8px;padding:15px}.collision-canvas{display:block;margin:15px auto;border:1px solid #495057;background:#fff;width:100%}.collision-btns{text-align:center;margin:12px 0;display:flex;flex-wrap:wrap;gap:6px;justify-content:center}.collision-btns button{padding:6px 12px;font-size:12px;cursor:pointer;background:#fff;color:#495057;border:2px solid #495057;border-radius:4px;transition:all 0.2s}.collision-btns button:hover{background:#e9ecef}.collision-btns button.active{background:#495057;color:#fff}.controls{background:#f8f9fa;padding:12px;border-radius:6px;margin-bottom:12px}.control-group{margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid #dee2e6}.control-group:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}.control-title{font-weight:bold;color:#495057;margin-bottom:6px;font-size:13px}.slider-pairs{display:grid;grid-template-columns:1fr 1fr;gap:10px}.slider-group{margin-bottom:0}.slider-label{display:flex;justify-content:space-between;font-size:11px;color:#495057;margin-bottom:3px}input[type="range"]{width:100%;height:5px;border-radius:3px;background:#dee2e6;outline:none;-webkit-appearance:none}input[type="range"]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:14px;height:14px;border-radius:50%;background:#495057;cursor:pointer}input[type="range"]::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:#495057;cursor:pointer;border:none}.info-box{text-align:center;font-family:monospace;font-size:11px;color:#495057;margin:8px 0;padding:6px;background:#f8f9fa;border-radius:4px}</style></head><body><div class="container"><h1>Collisions</h1><div class="panel"><canvas id="collision-canvas" class="collision-canvas" width="560" height="160"></canvas><div class="info-box" id="collision-type">Select a collision type to start</div><div class="collision-btns"><button id="elastic">Elastic</button><button id="inelastic">Inelastic</button><button id="perfect">Perfectly Inelastic</button></div><div class="controls"><div class="control-group"><div class="control-title">Box A & Box B</div><div class="slider-pairs"><div class="slider-group"><div class="slider-label"><span>Mass A</span><span id="mass1-val">2.0 kg</span></div><input type="range" id="mass1" min="0.5" max="5" step="0.5" value="2"></div><div class="slider-group"><div class="slider-label"><span>Mass B</span><span id="mass2-val">2.0 kg</span></div><input type="range" id="mass2" min="0.5" max="5" step="0.5" value="2"></div><div class="slider-group"><div class="slider-label"><span>Velocity A</span><span id="vel1-val">1.5 m/s</span></div><input type="range" id="vel1" min="-3" max="3" step="0.1" value="1.5"></div><div class="slider-group"><div class="slider-label"><span>Velocity B</span><span id="vel2-val">-0.5 m/s</span></div><input type="range" id="vel2" min="-3" max="3" step="0.1" value="-0.5"></div></div></div></div></div></div></body><script>const canvas=document.getElementById('collision-canvas');const ctx=canvas.getContext('2d');let ball1={x:145,y:80,vx:1.5,mass:2};let ball2={x:415,y:80,vx:-0.5,mass:2};let collisionType=null;let animating=false;let collided=false;let initialMomentum=0;function resetBalls(){ball1.x=145;ball2.x=415;collided=false}function updateBallsFromSliders(){ball1.mass=parseFloat(document.getElementById('mass1').value);ball1.vx=parseFloat(document.getElementById('vel1').value);ball2.mass=parseFloat(document.getElementById('mass2').value);ball2.vx=parseFloat(document.getElementById('vel2').value);initialMomentum=ball1.mass*ball1.vx+ball2.mass*ball2.vx;resetBalls()}function drawBall(ball,color){const boxSize=35+ball.mass*8;ctx.fillStyle=color;ctx.fillRect(ball.x-boxSize/2,ball.y-boxSize/2,boxSize,boxSize);ctx.strokeStyle='#000';ctx.lineWidth=2;ctx.strokeRect(ball.x-boxSize/2,ball.y-boxSize/2,boxSize,boxSize);ctx.fillStyle='#000';const fontSize=Math.max(8,boxSize*0.28);ctx.font='bold '+fontSize+'px Arial';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(ball.mass.toFixed(1)+' kg',ball.x,ball.y+2);ctx.fillStyle='#000';ctx.font='bold 12px Arial';ctx.textAlign='center';ctx.textBaseline='bottom';if(ball===ball1){ctx.fillText('A',ball.x,ball.y-boxSize/2-28);ctx.fillStyle='#ff0000';ctx.fillText(ball.vx.toFixed(2)+' m/s',ball.x,ball.y-boxSize/2-14)}else{ctx.fillText('B',ball.x,ball.y-boxSize/2-28);ctx.fillStyle='#ff0000';ctx.fillText(ball.vx.toFixed(2)+' m/s',ball.x,ball.y-boxSize/2-14)}}function drawVelocityVectors(){const boxSize1=35+ball1.mass*8;ctx.strokeStyle='#ff0000';ctx.lineWidth=2.5;const arrowLength1=Math.abs(ball1.vx)*12;const arrowDir1=ball1.vx>0?1:-1;ctx.beginPath();ctx.moveTo(ball1.x+boxSize1/2*arrowDir1,ball1.y);ctx.lineTo(ball1.x+boxSize1/2*arrowDir1+arrowLength1*arrowDir1,ball1.y);ctx.stroke();ctx.beginPath();ctx.moveTo(ball1.x+boxSize1/2*arrowDir1+arrowLength1*arrowDir1,ball1.y);ctx.lineTo(ball1.x+boxSize1/2*arrowDir1+arrowLength1*arrowDir1-5*arrowDir1,ball1.y-4);ctx.moveTo(ball1.x+boxSize1/2*arrowDir1+arrowLength1*arrowDir1,ball1.y);ctx.lineTo(ball1.x+boxSize1/2*arrowDir1+arrowLength1*arrowDir1-5*arrowDir1,ball1.y+4);ctx.stroke();const boxSize2=35+ball2.mass*8;ctx.strokeStyle='#ff0000';ctx.lineWidth=2.5;const arrowLength2=Math.abs(ball2.vx)*12;const arrowDir2=ball2.vx>0?1:-1;ctx.beginPath();ctx.moveTo(ball2.x+boxSize2/2*arrowDir2,ball2.y);ctx.lineTo(ball2.x+boxSize2/2*arrowDir2+arrowLength2*arrowDir2,ball2.y);ctx.stroke();ctx.beginPath();ctx.moveTo(ball2.x+boxSize2/2*arrowDir2+arrowLength2*arrowDir2,ball2.y);ctx.lineTo(ball2.x+boxSize2/2*arrowDir2+arrowLength2*arrowDir2-5*arrowDir2,ball2.y-4);ctx.moveTo(ball2.x+boxSize2/2*arrowDir2+arrowLength2*arrowDir2,ball2.y);ctx.lineTo(ball2.x+boxSize2/2*arrowDir2+arrowLength2*arrowDir2-5*arrowDir2,ball2.y+4);ctx.stroke()}function checkCollision(){const boxSize1=35+ball1.mass*8;const boxSize2=35+ball2.mass*8;const distance=Math.abs(ball2.x-ball1.x);if(distance<=boxSize1/2+boxSize2/2&&!collided){collided=true;const m1=ball1.mass;const m2=ball2.mass;const u1=ball1.vx;const u2=ball2.vx;const totalMomentum=m1*u1+m2*u2;if(collisionType==='elastic'){const v1f=((m1-m2)*u1+2*m2*u2)/(m1+m2);const v2f=(totalMomentum-m1*v1f)/m2;ball1.vx=v1f;ball2.vx=v2f}else if(collisionType==='inelastic'){const e=0.5;const v1f=((m1-e*m2)*u1+(1+e)*m2*u2)/(m1+m2);const v2f=(totalMomentum-m1*v1f)/m2;ball1.vx=v1f;ball2.vx=v2f}else if(collisionType==='perfect'){const vf=totalMomentum/(m1+m2);ball1.vx=vf;ball2.vx=vf;const midpoint=(ball1.x+ball2.x)/2;ball1.x=midpoint-(boxSize1/2+boxSize2/2)/2;ball2.x=midpoint+(boxSize1/2+boxSize2/2)/2}}}function updateMomentumDisplay(){}function animate(){ctx.clearRect(0,0,560,160);ctx.strokeStyle='#495057';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(0,130);ctx.lineTo(560,130);ctx.stroke();if(animating){ball1.x+=ball1.vx;ball2.x+=ball2.vx;checkCollision();if(ball1.x>600||ball1.x<-50||ball2.x>600||ball2.x<-50){animating=false}}drawBall(ball1,'#a8d5ff');drawBall(ball2,'#ffb3ba');drawVelocityVectors();requestAnimationFrame(animate)}function startSimulation(type){updateBallsFromSliders();collisionType=type;animating=true;const typeNames={elastic:'Elastic Collision',inelastic:'Inelastic Collision',perfect:'Perfectly Inelastic Collision'};document.getElementById('collision-type').textContent=typeNames[type];document.querySelectorAll('.collision-btns button').forEach(b=>b.classList.remove('active'));event.target.classList.add('active')}function updateSliderLabels(){document.getElementById('mass1-val').textContent=parseFloat(document.getElementById('mass1').value).toFixed(1)+' kg';document.getElementById('vel1-val').textContent=parseFloat(document.getElementById('vel1').value).toFixed(1)+' m/s';document.getElementById('mass2-val').textContent=parseFloat(document.getElementById('mass2').value).toFixed(1)+' kg';document.getElementById('vel2-val').textContent=parseFloat(document.getElementById('vel2').value).toFixed(1)+' m/s'}document.getElementById('elastic').addEventListener('click',function(){startSimulation('elastic')});document.getElementById('inelastic').addEventListener('click',function(){startSimulation('inelastic')});document.getElementById('perfect').addEventListener('click',function(){startSimulation('perfect')});document.getElementById('mass1').addEventListener('input',()=>{updateSliderLabels();updateBallsFromSliders()});document.getElementById('vel1').addEventListener('input',()=>{updateSliderLabels();updateBallsFromSliders()});document.getElementById('mass2').addEventListener('input',()=>{updateSliderLabels();updateBallsFromSliders()});document.getElementById('vel2').addEventListener('input',()=>{updateSliderLabels();updateBallsFromSliders()});updateSliderLabels();updateBallsFromSliders();animate();</script></html>